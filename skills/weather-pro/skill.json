{
  "name": "weather-pro",
  "version": "1.0.0",
  "description": "专业天气预报助手",
  "author": "小鬼",
  "commands": [
    {
      "pattern": "天气 (.+)",
      "action": "getWeather",
      "description": "查询城市天气"
    },
    {
      "pattern": "weather (.+)",
      "action": "getWeather",
      "description": "Query city weather"
    },
    {
      "pattern": "天气对比 (.+)",
      "action": "compareWeather",
      "description": "多城市天气对比"
    },
    {
      "pattern": "天气预警 (.+)",
      "action": "getAlerts",
      "description": "查询天气预警"
    },
    {
      "pattern": "详细天气 (.+)",
      "action": "getDetailedWeather",
      "description": "获取详细天气信息"
    },
    {
      "pattern": "7 天预报 (.+)",
      "action": "get7DayForecast",
      "description": "7 天天气预报"
    }
  ],
  "config": {
    "defaultCity": "北京",
    "unit": "celsius",
    "alertEnabled": true,
    "updateInterval": 30
  },
  "triggers": [
    {
      "type": "cron",
      "schedule": "0 8 * * *",
      "action": "sendDailyWeather"
    }
  ]
}
