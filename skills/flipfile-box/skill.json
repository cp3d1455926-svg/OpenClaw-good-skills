{
  "name": "flipfile-box",
  "version": "1.0.0",
  "description": "翻身文件箱 - 智能文件管理工具",
  "author": "小鬼",
  "commands": [
    {
      "pattern": "加密文件 (.+)",
      "action": "encryptFile",
      "description": "加密文件"
    },
    {
      "pattern": "解密文件 (.+)",
      "action": "decryptFile",
      "description": "解密文件"
    },
    {
      "pattern": "创建隐私空间",
      "action": "createSecureSpace",
      "description": "创建隐私空间"
    },
    {
      "pattern": "同步文件 (.+)",
      "action": "syncFile",
      "description": "同步文件"
    },
    {
      "pattern": "查看同步状态",
      "action": "syncStatus",
      "description": "查看同步状态"
    },
    {
      "pattern": "转换文件 (.+) 转 (.+)",
      "action": "convertFile",
      "description": "转换文件格式"
    },
    {
      "pattern": "批量转换 (.+) 转 (.+)",
      "action": "batchConvert",
      "description": "批量转换文件"
    },
    {
      "pattern": "粉碎文件 (.+)",
      "action": "shredFile",
      "description": "安全删除文件"
    }
  ],
  "config": {
    "encryptAlgo": "AES-256",
    "syncInterval": 5,
    "cloudProvider": "auto",
    "convertQuality": 90,
    "autoBackup": true,
    "secureSpacePath": "",
    "maxVersions": 10
  },
  "env": {
    "FLIPFILE_API_KEY": "optional",
    "CLOUD_STORAGE_PATH": "required"
  }
}
